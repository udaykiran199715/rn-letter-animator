{
  "name": "rn-letter-animator",
  "version": "0.1.0",
  "description": "Letter animator",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "rn-letter-animator-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "clean": "del-cli lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "example": "pnpm --filter rn-letter-animator-example",
    "example:start": "pnpm --filter rn-letter-animator-example start",
    "example:android": "pnpm --filter rn-letter-animator-example android",
    "example:ios": "pnpm --filter rn-letter-animator-example ios",
    "example:web": "pnpm --filter rn-letter-animator-example web"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udaykiran199715/rn-letter-animator.git"
  },
  "author": "udaykiran199715 <udaykiran199715@gmail.com> (https://github.com/udaykiran199715)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/udaykiran199715/rn-letter-animator/issues"
  },
  "homepage": "https://github.com/udaykiran199715/rn-letter-animator#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.43.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "pnpm@10.28.2",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.63.0"
  },
  "dependencies": {
    "react-native-reanimated": "^4.5.1"
  }
}
